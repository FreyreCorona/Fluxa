services:
  uptime-kuma:
    image: louislam/uptime-kuma:1
    container_name: uptime-kuma
    restart: unless-stopped
    volumes:
      - ./data:/app/data
    healthcheck:
      test: ["CMD", "node", "server/server.js", "--health"]
      interval: 30s
      timeout: 10s
      retries: 3
    ports:
      - "3001:3001"
