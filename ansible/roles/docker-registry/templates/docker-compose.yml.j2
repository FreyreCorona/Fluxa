services:
  registry:
    image: registry:3
    container_name: platform-registry
    restart: unless-stopped
    volumes:
      - ./data:/var/lib/registry
    healthcheck:
      test: ["CMD", "wget", "--spider", "http://localhost:5000/v2/"]
      interval: 30s
      timeout: 10s
      retries: 3
    ports:
      - "5000:5000"
